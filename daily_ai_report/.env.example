# ─── OpenAI / LLM API ───
# 必填。OpenAI API Key（或其他兼容接口的 Key）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# ─── 邮件推送（支持 Gmail / QQ邮箱 / 任意 SMTP） ───
# Gmail 示例
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=你的Gmail@gmail.com
EMAIL_AUTH_CODE=Gmail应用专用密码（16位，不是登录密码）
EMAIL_RECEIVER=接收日报的邮箱

# QQ邮箱 示例（如用 QQ 则改上面为 smtp.qq.com + 授权码）
# EMAIL_SMTP_HOST=smtp.qq.com
# EMAIL_SMTP_PORT=587
# EMAIL_SENDER=你的QQ号@qq.com
# EMAIL_AUTH_CODE=QQ邮箱授权码
# EMAIL_RECEIVER=接收日报的邮箱

# ─── Notion 推送（可选） ───
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=数据库ID（32位UUID）

# ─── 研究方向偏好，逗号分隔 ───
RESEARCH_KEYWORDS=landslide detection,remote sensing,semantic segmentation,SAR,deep learning,object detection,change detection
