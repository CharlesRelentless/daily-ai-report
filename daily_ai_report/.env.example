# ─── OpenAI / LLM API ───
# 必填。OpenAI API Key（或其他兼容接口的 Key）
OPENAI_API_KEY=sk-your-key-here

# 可选。若使用兼容接口（如 Azure、本地模型），修改以下两项
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ─── QQ邮箱 SMTP 推送 ───
# 必填。QQ邮箱 + 授权码（非密码，在 QQ邮箱 → 设置 → 账户 → POP3/SMTP 服务 → 生成授权码）
QQMAIL_SENDER=你的QQ号@qq.com
QQMAIL_AUTH_CODE=你的授权码
QQMAIL_RECEIVER=接收日报的邮箱

# ─── Notion 推送（可选） ───
# 必填项如果启用 Notion 推送
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=数据库ID（32位UUID）

# ─── 研究方向偏好，逗号分隔 ───
RESEARCH_KEYWORDS=landslide detection,remote sensing,semantic segmentation,SAR,deep learning,object detection,change detection
